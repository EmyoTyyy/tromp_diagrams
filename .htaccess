# ───────────────────────────────────────────────────────────────
# Apache config — only used when the site is served by Apache
# (e.g. shared hosting like OVH, DreamHost, A2). Other hosts
# (GitHub Pages, Netlify, Cloudflare Pages, Vercel) ignore this
# file completely.
# ───────────────────────────────────────────────────────────────

# Custom 404 page.
ErrorDocument 404 /404.html

# Slightly nicer caching for static assets. Tweak as needed.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html              "access plus 0 seconds"
  ExpiresByType text/css               "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/svg+xml          "access plus 30 days"
</IfModule>
